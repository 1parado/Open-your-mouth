# LLM Provider Configuration
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your-llm-api-key
LLM_MODEL=gpt-4o-mini

# ASR Provider Configuration
ASR_BASE_URL=https://api.openai.com/v1
ASR_API_KEY=your-asr-api-key
ASR_MODEL=whisper-1

# TTS Provider Configuration
TTS_BASE_URL=https://api.openai.com/v1
TTS_API_KEY=your-tts-api-key
TTS_MODEL=tts-1

# Pronunciation Assessment Provider Configuration
PRONUNCIATION_BASE_URL=http://localhost:8092/v1
PRONUNCIATION_API_KEY=your-pronunciation-api-key
PRONUNCIATION_MODEL=pronunciation-v1

# Azure OpenAI Alternative (Optional)
AZURE_OPENAI_BASE_URL=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-azure-api-key
AZURE_OPENAI_MODEL=gpt-4o-mini

AZURE_ASR_BASE_URL=https://your-resource.openai.azure.com
AZURE_ASR_API_KEY=your-azure-api-key
AZURE_ASR_MODEL=whisper-1

AZURE_TTS_BASE_URL=https://your-resource.openai.azure.com
AZURE_TTS_API_KEY=your-azure-api-key
AZURE_TTS_MODEL=tts-1

AZURE_PRONUNCIATION_BASE_URL=http://localhost:8092/v1
AZURE_PRONUNCIATION_API_KEY=your-azure-pronunciation-api-key
AZURE_PRONUNCIATION_MODEL=azure-pron-v1
